<!DOCTYPE html>
<html>
<head>
    <title>Online Movie Booking</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">

    <style>
        *{margin:0;padding:0;box-sizing:border-box;font-family:'Poppins',sans-serif;}

        body{
            height:100vh;
            background:url('https://images.unsplash.com/photo-1489599849927-2ee91cede3ba') no-repeat center/cover;
            display:flex;
            justify-content:center;
            align-items:center;
            position:relative;
        }

        body::before{
            content:"";
            position:absolute;
            width:100%;
            height:100%;
            background:rgba(0,0,0,0.6);
        }

        .container{
            position:relative;
            z-index:1;
            background:rgba(255,255,255,0.15);
            backdrop-filter:blur(12px);
            padding:40px;
            border-radius:15px;
            width:400px;
            color:white;
            text-align:center;
            box-shadow:0 8px 32px rgba(0,0,0,0.4);
        }

        h2,h3,h4{margin-bottom:20px;}

        input{
            width:100%;
            padding:12px;
            margin:10px 0;
            border:none;
            border-radius:8px;
            outline:none;
        }

        button{
            width:100%;
            padding:12px;
            border:none;
            border-radius:8px;
            font-weight:bold;
            cursor:pointer;
            background:linear-gradient(90deg,#ff512f,#dd2476);
            color:white;
            transition:0.3s;
        }

        button:hover{
            transform:scale(1.05);
        }

        .movie-card{
            background:rgba(255,255,255,0.1);
            padding:20px;
            margin:15px auto;
            border-radius:10px;
            cursor:pointer;
        }

        .movie-card:hover{
            background:rgba(255,255,255,0.2);
        }

        .back-btn{
            background:gray;
            margin-top:15px;
        }
    </style>
</head>

<body>

<!-- PAGE 1 : USER DETAILS -->
<div class="container" id="page1">
    <h2>🎬 Movie Booking</h2>
    <input type="text" id="name" placeholder="Enter Your Name">
    <input type="number" id="age" placeholder="Enter Your Age">
    <button onclick="goToMovies()">Next</button>
</div>


<!-- PAGE 2 : MOVIE LIST -->
<div class="container" id="page2" style="display:none;">
    <h2>Welcome <span id="userName"></span> 👋</h2>
    <h3>Now Showing</h3>

    <div class="movie-card" onclick="goToMovieDetail('Leo','Action','Vijay','3 Hours','₹200')">
        <h4>Leo</h4>
        <p>Genre : Action</p>
    </div>

    <div class="movie-card" onclick="goToMovieDetail('Jailer','Action/Drama','Rajinikanth','2.45 Hours','₹220')">
        <h4>Jailer</h4>
        <p>Genre : Action / Drama</p>
    </div>

    <div class="movie-card" onclick="goToMovieDetail('Avengers Endgame','Superhero','Marvel Studios','3 Hours','₹250')">
        <h4>Avengers Endgame</h4>
        <p>Genre : Superhero</p>
    </div>

    <button class="back-btn" onclick="backToForm()">Back</button>
</div>


<!-- PAGE 3 : MOVIE DETAILS -->
<div class="container" id="page3" style="display:none;">
    <h2 id="movieTitle"></h2>

    <p><b>Genre:</b> <span id="movieGenre"></span></p>
    <p><b>Lead Actor:</b> <span id="movieActor"></span></p>
    <p><b>Duration:</b> <span id="movieDuration"></span></p>
    <p><b>Ticket Price:</b> <span id="moviePrice"></span></p>

    <button onclick="bookTicket()">Book Ticket</button>
    <button class="back-btn" onclick="backToMovies()">Back</button>
</div>


<script>

function goToMovies(){

    var name=document.getElementById("name").value;
    var age=document.getElementById("age").value;

    if(name==="" || age===""){
        alert("Please enter Name and Age");
        return;
    }

    document.getElementById("page1").style.display="none";
    document.getElementById("page2").style.display="block";

    document.getElementById("userName").innerText=name;
}


function goToMovieDetail(title,genre,actor,duration,price){

    document.getElementById("page2").style.display="none";
    document.getElementById("page3").style.display="block";

    document.getElementById("movieTitle").innerText=title;
    document.getElementById("movieGenre").innerText=genre;
    document.getElementById("movieActor").innerText=actor;
    document.getElementById("movieDuration").innerText=duration;
    document.getElementById("moviePrice").innerText=price;
}


function backToForm(){

    document.getElementById("page2").style.display="none";
    document.getElementById("page1").style.display="block";

}


function backToMovies(){

    document.getElementById("page3").style.display="none";
    document.getElementById("page2").style.display="block";

}


function bookTicket(){

    alert("🎟️ Ticket Booked Successfully!");

}

</script>

</body>
</html>
